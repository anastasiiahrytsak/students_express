<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Heroes</title>
  <style>

    html, body {
      background-color: #000000; 
      min-height: 100vh;
      margin: 0;
      /* Використовуємо системний шрифт Apple */
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #F2F2F7;
      box-sizing: border-box;
      padding: 30px 20px;
      display: flex;
      flex-direction: column;
      align-items: center; 
    }

    .container {
      background-color: #1C1C1E; /* Темно-сірий колір карток iOS */
      border-radius: 16px;
      padding: 20px;
      width: 100%;
      max-width: 1000px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    }

    .top-buttons {
      margin-bottom: 25px;
      display: flex;
      gap: 12px;
      align-items: center;
    }

    /* Спільні стилі для кнопок */
    .btn {
      border: none;
      border-radius: 12px; /* Приємне заокруглення */
      padding: 10px 18px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), filter 0.2s;
    }

    /* Ефект збільшення при наведенні */
    .btn:hover {
      transform: scale(1.05);
      filter: brightness(1.1);
    }

    /* Індивідуальні кольори кнопок (палітра iOS) */
    .btn-back {
      background-color: #3A3A3C; /* Системний сірий */
      color: #FFFFFF;
    }
    
    .btn-add {
      background-color: #0A84FF; /* iOS Blue */
      color: #FFFFFF;
    }

    .btn-edit {
      background-color: #3A3A3C; 
      color: #0A84FF; /* Синій текст на сірому фоні для другорядних дій */
      padding: 8px 14px;
    }

    .btn-delete {
      background-color: rgba(255, 69, 58, 0.15); /* Прозорий червоний фон */
      color: #FF453A; /* iOS Red */
      padding: 8px 14px;
    }

    /* Таблиця */
    table {
      border-collapse: collapse;
      text-align: left;
      width: 100%;
    }

    /* Шапка таблиці */
    th {
      color: #8E8E93; /* Світло-сірий текст для заголовків */
      font-size: 13px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 12px 16px;
      border-bottom: 1px solid #3A3A3C; /* Тонка лінія знизу */
    }

    /* Звичайні комірки */
    td {
      padding: 16px;
      border-bottom: 1px solid #2C2C2E; /* Дуже слабка лінія між рядками */
      vertical-align: middle;
      font-size: 15px;
    }

    /* Прибираємо лінію в останнього рядка, щоб виглядало охайно */
    tr:last-child td {
      border-bottom: none;
    }

    /* Легке підсвічування рядка при наведенні миші (ефект вибору в iOS) */
    tr:hover td {
      background-color: rgba(255, 255, 255, 0.03);
    }
    
    /* Контейнер для дій в таблиці */
    .actions-cell {
      display: flex;
      gap: 8px;
    }
  </style>
</head>
<body>

<div class="container">
  <div class="top-buttons">
    <a href="/" class="btn btn-back">GO BACK</a>
    <button id="add-hero-btn" class="btn btn-add">Add New Hero</button>
  </div>

  <table>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Primary Attribute</th>
      <th>Role</th>
      <th>Difficulty</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>

    {{#each heroes}}
    <tr>
      <td>{{id}}</td>
      <td style="font-weight: 600;">{{name}}</td>
      <td>{{primary_attribute}}</td>
      <td>{{role}}</td>
      <td>{{attack_type}}</td>
      <td style="color: #8E8E93; font-size: 13px;">{{created_at_date}}<br>{{created_at_time}}</td>
      <td class="actions-cell">
        <a href="/heroes/edit/{{id}}" style="text-decoration: none;">
          <button class="btn btn-edit">Edit</button>
        </a>
        <button class="btn btn-delete delete-hero-btn" data-id="{{id}}">Delete</button>
      </td>
    </tr>
    {{/each}}
  </table>
</div>

<script>
  const addBtn = document.getElementById('add-hero-btn');
  if (addBtn) {
    addBtn.addEventListener('click', function() {
      window.location.href = '/heroes/add'; 
    });
  }

  const deleteBtns = document.querySelectorAll('.delete-hero-btn');
  deleteBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      const heroId = this.getAttribute('data-id');
      
      if (confirm('Are you sure you want to delete the hero with ID: ' + heroId + '?')) {
        fetch('/heroes/' + heroId, {
          method: 'DELETE'
        })
        .then(response => {
          if (response.ok) {
            window.location.reload();
          } else {
            alert('Error! Failed to delete the hero.');
          }
        });
      }
    });
  });
</script>

</body>
</html>